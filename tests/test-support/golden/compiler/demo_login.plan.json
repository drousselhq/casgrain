{
  "plan_id": "successful-login",
  "name": "Successful login",
  "version": {
    "major": 1,
    "minor": 0
  },
  "source": {
    "kind": "gherkin",
    "source_name": "docs/gherkin/demo-login.feature",
    "compiler_version": "0.1.0"
  },
  "target": {
    "platform": "cross_platform",
    "device_class": "simulator"
  },
  "capabilities_required": {
    "capabilities": []
  },
  "defaults": {
    "step_timeout_ms": 5000,
    "poll_interval_ms": 250,
    "artifact_mode": "failure_only"
  },
  "steps": [
    {
      "step_id": "successful-login-001",
      "intent": "setup",
      "description": "the app is launched",
      "action": {
        "kind": "launch_app",
        "app_id": "app.under.test"
      },
      "guards": [],
      "postconditions": [
        {
          "kind": "app_in_foreground",
          "app_id": "app.under.test"
        }
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1
      },
      "on_failure": "abort_run",
      "artifacts": {
        "capture_on_failure": true,
        "capture_after_step": false
      }
    },
    {
      "step_id": "successful-login-002",
      "intent": "interact",
      "description": "the user enters \"daniel@example.com\" into email field",
      "action": {
        "kind": "type_text",
        "target": {
          "kind": "text",
          "value": {
            "value": "email",
            "match_kind": "contains"
          }
        },
        "text": "daniel@example.com"
      },
      "guards": [],
      "postconditions": [],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1
      },
      "on_failure": "abort_run",
      "artifacts": {
        "capture_on_failure": true,
        "capture_after_step": false
      }
    },
    {
      "step_id": "successful-login-003",
      "intent": "interact",
      "description": "the user taps login button",
      "action": {
        "kind": "tap",
        "target": {
          "kind": "text",
          "value": {
            "value": "login",
            "match_kind": "contains"
          }
        }
      },
      "guards": [],
      "postconditions": [],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1
      },
      "on_failure": "abort_run",
      "artifacts": {
        "capture_on_failure": true,
        "capture_after_step": false
      }
    },
    {
      "step_id": "successful-login-004",
      "intent": "interact",
      "description": "the user takes a screenshot",
      "action": {
        "kind": "take_screenshot",
        "name": null
      },
      "guards": [],
      "postconditions": [],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1
      },
      "on_failure": "abort_run",
      "artifacts": {
        "capture_on_failure": true,
        "capture_after_step": false
      }
    },
    {
      "step_id": "successful-login-005",
      "intent": "assert",
      "description": "Home is visible",
      "action": {
        "kind": "noop"
      },
      "guards": [
        {
          "kind": "for_assertion",
          "assertion": {
            "kind": "visible",
            "target": {
              "kind": "text",
              "value": {
                "value": "home",
                "match_kind": "contains"
              }
            }
          }
        }
      ],
      "postconditions": [
        {
          "kind": "visible",
          "target": {
            "kind": "text",
            "value": {
              "value": "home",
              "match_kind": "contains"
            }
          }
        }
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1
      },
      "on_failure": "abort_run",
      "artifacts": {
        "capture_on_failure": true,
        "capture_after_step": false
      }
    }
  ],
  "metadata": {
    "feature_name": "Login"
  }
}